# EmailJS — https://emailjs.com
# All four values are required. Set them in Vercel → Settings → Environment Variables.
# Never put real values in this file.

EMAILJS_SERVICE_ID=your_service_id
EMAILJS_TEMPLATE_ID=your_template_id
EMAILJS_PUBLIC_KEY=your_public_key
EMAILJS_PRIVATE_KEY=your_private_key

# Your deployed Vercel URL — used to block requests from other origins
# Example: https://date-proposal.vercel.app
ALLOWED_ORIGIN=https://your-project.vercel.app
